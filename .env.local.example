# Copy to .env.local and fill in once the Supabase project exists.
# See specs/implementation-plan.md M0 and decisions/0005 / 0006 for why these
# specific values (mock payments/notifications need no third-party keys yet).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser. Used only inside Server Actions
# / Route Handlers per src/lib/supabase/service-role.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Launch-city default used to seed a new profile's `city` field.
NEXT_PUBLIC_LAUNCH_CITY=Bangalore
